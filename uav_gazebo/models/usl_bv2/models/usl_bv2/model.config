<?xml version="1.0"?>

<model>
  <name>usl_bv2</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>

  <author>
    <name>Luwei Liao</name>
    <email>liaoluweillw@163.com</email>
  </author>

  <maintainer email="liaoluweillw@163.com">Luwei Liao</maintainer>


  <description>
    starting with iris_with_standoffs
    add LiftDragPlugin
    add ArduCopterPlugin
    attach gimbal_small_2d model with GimbalSmall2dPlugin
  </description>
  <depend>
    <model>
      <uri>model://usl_bv2_base</uri>
      <version>1.0</version>
    </model>
    <model>
      <uri>model://usl_bv2_tilt</uri>
      <version>1.0</version>
    </model>
    <model>
      <uri>model://usl_bv2_prop</uri>
      <version>1.0</version>
    </model>
    <model>
      <uri>model://usl_bv2_leg</uri>
      <version>1.0</version>
    </model>
    <model>
      <uri>model://usl_bv2_wheel</uri>
      <version>1.0</version>
    </model>
  </depend>
</model>