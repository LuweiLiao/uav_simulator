<?xml version="1.0" ?>
  
  <sdf version="1.5">
    <model name="usl_bicopter">
      
      <include>
        <uri>model://usl_bicopter_base</uri>
        <name>usl_bicopter_base</name>
        <pose>0 0 0.0 0 0 0</pose>
      </include>
      
      
      <include>
        <uri>model://usl_bicopter_tilt</uri>
        <name>usl_bicopter_tilt_0</name>
        <pose relative_to="usl_bicopter_tilt_0_joint">0 0 0 0 0 0</pose>
      </include>
      <joint name = "usl_bicopter_tilt_0_joint" type="revolute">
        <pose relative_to="usl_bicopter_base::base">0.0 -0.15949 0.09516 0 0 3.141592653589793</pose>
        <parent>usl_bicopter_base::base</parent>
        <child>usl_bicopter_tilt_0::tilt</child>
        <axis>
          <xyz>0 -1 0</xyz>
          <limit>
            <lower>-1e+16</lower>
            <upper>1e+16</upper>
          </limit>
          <dynamics>
            <damping>0.1</damping>
            <spring_stiffness>0</spring_stiffness>
            <spring_reference>0</spring_reference>
          </dynamics>
          <use_parent_model_frame>1</use_parent_model_frame>
        </axis>
        <physics>
          <ode>
            <implicit_spring_damper>1</implicit_spring_damper>
          </ode>
        </physics>
      </joint>
    
      <include>
        <uri>model://usl_bicopter_tilt</uri>
        <name>usl_bicopter_tilt_1</name>
        <pose relative_to="usl_bicopter_tilt_1_joint">0 0 0 0 0 0</pose>
      </include>
      <joint name = "usl_bicopter_tilt_1_joint" type="revolute">
        <pose relative_to="usl_bicopter_base::base">0.0 0.15949 0.09516 0 0 0</pose>
        <parent>usl_bicopter_base::base</parent>
        <child>usl_bicopter_tilt_1::tilt</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-1e+16</lower>
            <upper>1e+16</upper>
          </limit>
          <dynamics>
            <damping>0.1</damping>
            <spring_stiffness>0</spring_stiffness>
            <spring_reference>0</spring_reference>
          </dynamics>
          <use_parent_model_frame>1</use_parent_model_frame>
        </axis>
        <physics>
          <ode>
            <implicit_spring_damper>1</implicit_spring_damper>
          </ode>
        </physics>
      </joint>
    
    
    
  <include>
    <uri>model://usl_bicopter_prop</uri>
    <name>usl_bicopter_prop_0</name>
    <pose relative_to="usl_bicopter_prop_0_joint">0 0 0 0 0 0</pose>
  </include>
  <joint name = "usl_bicopter_prop_0_joint" type="revolute">
    <pose relative_to="usl_bicopter_tilt_0::tilt">0.0 -0.0 0.05 0 0 0</pose>
    <parent>usl_bicopter_tilt_0::tilt</parent>
    <child>usl_bicopter_prop_0::prop</child>
    <axis>
      <xyz>0 0 1</xyz>
      <limit>
        <lower>-1e+16</lower>
        <upper>1e+16</upper>
      </limit>
      <dynamics>
        <damping>0.004</damping>
      </dynamics>
      <use_parent_model_frame>1</use_parent_model_frame>
    </axis>
    <physics>
      <ode>
        <implicit_spring_damper>1</implicit_spring_damper>
      </ode>
    </physics>
  </joint>

  <include>
    <uri>model://usl_bicopter_prop</uri>
    <name>usl_bicopter_prop_1</name>
    <pose relative_to="usl_bicopter_prop_1_joint">0 0 0 0 0 0</pose>
  </include>
  <joint name = "usl_bicopter_prop_1_joint" type="revolute">
    <pose relative_to="usl_bicopter_tilt_1::tilt">0.0 0.0 0.05 0 0 0</pose>
    <parent>usl_bicopter_tilt_1::tilt</parent>
    <child>usl_bicopter_prop_1::prop</child>
    <axis>
      <xyz>0 0 1</xyz>
      <limit>
        <lower>-1e+16</lower>
        <upper>1e+16</upper>
      </limit>
      <dynamics>
        <damping>0.004</damping>
      </dynamics>
      <use_parent_model_frame>1</use_parent_model_frame>
    </axis>
    <physics>
      <ode>
        <implicit_spring_damper>1</implicit_spring_damper>
      </ode>
    </physics>
  </joint>


</model>
</sdf>
