<?xml version="1.0" ?>
  <%
tilt1_pos_dx = 0.7
tilt1_pos_dy = 0.7
tilt1_pos_dz = 0

tilt1_pid_p = 3
tilt1_pid_i = 1.2
tilt1_pid_d = 0.8

tilt_back_pos_dx = 0.7
tilt_back_pos_dy = 0.0
tilt_back_pos_dz = 0

front_rod_length = 1.0
front_rod_radius = 0.05
front_rod_mass = 0.1
front_rod_center_x = 0.375 + front_rod_length / 2.0
front_rod_ixx = 0.1
front_rod_iyy = 0.1
front_rod_izz = 0.1

front_frame_near_width = 0.25
front_frame_near_height = 0.18
front_frame_far_width = 0.45
front_frame_far_height = 0.28
front_frame_radius = 0.015
front_frame_material = "Gazebo/Black"

front_frame_near_x = -front_rod_length / 2.0
front_frame_far_x = front_rod_length / 2.0
front_frame_points = {
  "near_left_top" => [front_frame_near_x, -front_frame_near_width / 2.0, front_frame_near_height / 2.0],
  "near_right_top" => [front_frame_near_x, front_frame_near_width / 2.0, front_frame_near_height / 2.0],
  "near_left_bottom" => [front_frame_near_x, -front_frame_near_width / 2.0, -front_frame_near_height / 2.0],
  "near_right_bottom" => [front_frame_near_x, front_frame_near_width / 2.0, -front_frame_near_height / 2.0],
  "far_left_top" => [front_frame_far_x, -front_frame_far_width / 2.0, front_frame_far_height / 2.0],
  "far_right_top" => [front_frame_far_x, front_frame_far_width / 2.0, front_frame_far_height / 2.0],
  "far_left_bottom" => [front_frame_far_x, -front_frame_far_width / 2.0, -front_frame_far_height / 2.0],
  "far_right_bottom" => [front_frame_far_x, front_frame_far_width / 2.0, -front_frame_far_height / 2.0],
}
front_frame_bars = [
  {:name => "near_top", :from => "near_left_top", :to => "near_right_top"},
  {:name => "near_bottom", :from => "near_left_bottom", :to => "near_right_bottom"},
  {:name => "near_left", :from => "near_left_top", :to => "near_left_bottom"},
  {:name => "near_right", :from => "near_right_top", :to => "near_right_bottom"},
  {:name => "far_top", :from => "far_left_top", :to => "far_right_top"},
  {:name => "far_bottom", :from => "far_left_bottom", :to => "far_right_bottom"},
  {:name => "far_left", :from => "far_left_top", :to => "far_left_bottom"},
  {:name => "far_right", :from => "far_right_top", :to => "far_right_bottom"},
  {:name => "left_top", :from => "near_left_top", :to => "far_left_top"},
  {:name => "right_top", :from => "near_right_top", :to => "far_right_top"},
  {:name => "left_bottom", :from => "near_left_bottom", :to => "far_left_bottom"},
  {:name => "right_bottom", :from => "near_right_bottom", :to => "far_right_bottom"},
]


tilt1_motors={
	"0" => {:tilt1_dx => tilt1_pos_dx,      :tilt1_dy => -tilt1_pos_dy,     :tilt1_dz => tilt1_pos_dz,      :tilt1_rot => 0,        :dir => 1,    :link_name => "tilt_tricopter_tilt_front_0",  :link => "tilt_tricopter_tilt_front"},
	"1" => {:tilt1_dx => -tilt_back_pos_dx, :tilt1_dy => tilt_back_pos_dy,  :tilt1_dz => tilt_back_pos_dz,  :tilt1_rot => 0,        :dir => 1,    :link_name => "tilt_tricopter_tilt_back_0",   :link => "tilt_tricopter_tilt_back"},
	"2" => {:tilt1_dx => tilt1_pos_dx,      :tilt1_dy =>  tilt1_pos_dy,     :tilt1_dz => tilt1_pos_dz,      :tilt1_rot => Math::PI, :dir => -1,   :link_name => "tilt_tricopter_tilt_front_1",  :link => "tilt_tricopter_tilt_front"},
}

prop_pos_dx = tilt1_pos_dx
prop_pos_dy = tilt1_pos_dy
prop_pos_dz = 0.0647

prop_timeConstantUp = 0.0125
prop_timeConstantDown = 0.025
prop_maxRotVelocity = 1000
prop_motorConstant = 1.199e-5
prop_momentConstant = 0.1

prop_back_pos_dx = tilt_back_pos_dx
prop_back_pos_dy = tilt_back_pos_dy
prop_back_pos_dz = 0.0647

prop_motors={
	"0" => {:prop_dx => prop_pos_dx,        :prop_dy => -prop_pos_dy,       :prop_dz => prop_pos_dz,        :dir => "ccw",     :parent_jont => "tilt_tricopter_tilt_front_0::tilt",  :link => "tilt_tricopter_prop"},
	"1" => {:prop_dx => prop_pos_dx,        :prop_dy => -prop_pos_dy,       :prop_dz => -prop_pos_dz,       :dir => "cw",    :parent_jont => "tilt_tricopter_tilt_front_0::tilt",  :link => "tilt_tricopter_prop"},
	"2" => {:prop_dx => -prop_back_pos_dx,  :prop_dy => -prop_back_pos_dy,  :prop_dz => prop_back_pos_dz,   :dir => "ccw",     :parent_jont => "tilt_tricopter_tilt_back_0::tilt",   :link => "tilt_tricopter_prop"},
	"3" => {:prop_dx => -prop_back_pos_dx,  :prop_dy => -prop_back_pos_dy,  :prop_dz => -prop_back_pos_dz,  :dir => "cw",    :parent_jont => "tilt_tricopter_tilt_back_0::tilt",   :link => "tilt_tricopter_prop"},
	"4" => {:prop_dx => prop_pos_dx,        :prop_dy => prop_pos_dy,        :prop_dz => prop_pos_dz,        :dir => "ccw",     :parent_jont => "tilt_tricopter_tilt_front_1::tilt",  :link => "tilt_tricopter_prop"},
	"5" => {:prop_dx => prop_pos_dx,        :prop_dy => prop_pos_dy,        :prop_dz => -prop_pos_dz,       :dir => "cw",    :parent_jont => "tilt_tricopter_tilt_front_1::tilt",  :link => "tilt_tricopter_prop"},
}

%>
  <sdf version="1.5">
    <model name="tilt_tricopter">
      <%# ====================================================================================== %>
      <include>
        <uri>model://tilt_tricopter_base</uri>
        <name>tilt_tricopter_base</name>
        <pose>0 0 0.0 0 0 0</pose>
      </include>
      <link name="front_rod">
        <pose><%= front_rod_center_x %> 0 0 0 0 0</pose>
        <inertial>
          <pose>0 0 0 0 0 0</pose>
          <mass><%= front_rod_mass %></mass>
          <inertia>
            <ixx><%= front_rod_ixx %></ixx>
            <iyy><%= front_rod_iyy %></iyy>
            <izz><%= front_rod_izz %></izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="front_rod_collision">
          <pose>0 0 0 0 1.57079632679 0</pose>
          <geometry>
            <cylinder>
              <length><%= front_rod_length %></length>
              <radius><%= front_rod_radius %></radius>
            </cylinder>
          </geometry>
        </collision>
        <visual name="front_rod_visual">
          <pose>0 0 0 0 1.57079632679 0</pose>
          <geometry>
            <cylinder>
              <length><%= front_rod_length %></length>
              <radius><%= front_rod_radius %></radius>
            </cylinder>
          </geometry>
          <material>
            <script>
              <name>Gazebo/Black</name>
            </script>
          </material>
        </visual>
        <%
          front_frame_bars.each do |bar|
            start_point = front_frame_points[bar[:from]]
            end_point = front_frame_points[bar[:to]]
            dx = end_point[0] - start_point[0]
            dy = end_point[1] - start_point[1]
            dz = end_point[2] - start_point[2]
            bar_length = Math.sqrt(dx * dx + dy * dy + dz * dz)
            bar_mid_x = (start_point[0] + end_point[0]) / 2.0
            bar_mid_y = (start_point[1] + end_point[1]) / 2.0
            bar_mid_z = (start_point[2] + end_point[2]) / 2.0
            bar_roll = 0
            bar_pitch = Math.atan2(Math.sqrt(dx * dx + dy * dy), dz)
            bar_yaw = Math.atan2(dy, dx)
        %>
        <collision name=<%= '"front_frame_' + bar[:name] + '_collision"' %>>
          <pose><%= bar_mid_x %> <%= bar_mid_y %> <%= bar_mid_z %> <%= bar_roll %> <%= bar_pitch %> <%= bar_yaw %></pose>
          <geometry>
            <cylinder>
              <length><%= bar_length %></length>
              <radius><%= front_frame_radius %></radius>
            </cylinder>
          </geometry>
        </collision>
        <visual name=<%= '"front_frame_' + bar[:name] + '_visual"' %>>
          <pose><%= bar_mid_x %> <%= bar_mid_y %> <%= bar_mid_z %> <%= bar_roll %> <%= bar_pitch %> <%= bar_yaw %></pose>
          <geometry>
            <cylinder>
              <length><%= bar_length %></length>
              <radius><%= front_frame_radius %></radius>
            </cylinder>
          </geometry>
          <material>
            <script>
              <name><%= front_frame_material %></name>
            </script>
          </material>
        </visual>
        <% end %>
      </link>
      <joint name="front_rod_joint" type="fixed">
        <parent>tilt_tricopter_base::base</parent>
        <child>front_rod</child>
      </joint>
      <%# ====================================================================================== %>
      <%
			tilt1_motors.keys.each do |k|
				tilt1_dx = tilt1_motors[k][:tilt1_dx]
				tilt1_dy = tilt1_motors[k][:tilt1_dy]
				tilt1_dz = tilt1_motors[k][:tilt1_dz]
				tilt1_rot = tilt1_motors[k][:tilt1_rot]
				dir = tilt1_motors[k][:dir]
        link_name = tilt1_motors[k][:link_name]
        link = tilt1_motors[k][:link]
			%>
      <include>
        <uri><%="model://" + link %></uri>
        <name><%=link_name %></name>
        <pose><%= tilt1_dx %> <%= tilt1_dy %> <%= tilt1_dz %> 0 0 <%= tilt1_rot %></pose>
      </include>
      <joint name = <%= link_name + '_joint' %> type="revolute">
        <parent>tilt_tricopter_base::base</parent>
        <child><%=link_name + '::tilt' %></child>
        <axis>
          <xyz>0 <%=dir%> 0</xyz>
          <limit>
            <lower>-1e+16</lower>
            <upper>1e+16</upper>
          </limit>
          <dynamics>
            <damping>0.1</damping>
            <spring_stiffness>0</spring_stiffness>
            <spring_reference>0</spring_reference>
          </dynamics>
          <use_parent_model_frame>1</use_parent_model_frame>
        </axis>
        <physics>
          <ode>
            <implicit_spring_damper>1</implicit_spring_damper>
          </ode>
        </physics>
      </joint>
      <plugin name = <%= link_name + '_plugin' %> filename='librotors_gazebo_motor_model.so'>
        <robotNamespace></robotNamespace>
        <jointName><%=link_name + '_joint'%> </jointName>
        <linkName><%=link_name + '::tilt' %></linkName>
        <turningDirection>cw</turningDirection>
        <motorType>position</motorType>
        <commandSubTopic>/gazebo/command/tilt1_pos</commandSubTopic>
        <motorNumber><%= k %></motorNumber>
        <motorSpeedPubTopic><%= 'tilt_pos/' + k %></motorSpeedPubTopic>
        <joint_control_pid>
          <p><%= tilt1_pid_p %></p>
          <i><%= tilt1_pid_i %></i>
          <d><%= tilt1_pid_d %></d>
          <iMax>10</iMax>
          <iMin>-10</iMin>
          <cmdMax>50</cmdMax>
          <cmdMin>-50</cmdMin>
        </joint_control_pid>
      </plugin>
    <% end %>    
  <%# ====================================================================================== %>
  <%
			prop_motors.keys.each do |k|
				prop_dx = prop_motors[k][:prop_dx]
				prop_dy = prop_motors[k][:prop_dy]
				prop_dz = prop_motors[k][:prop_dz]
				dir = prop_motors[k][:dir]
        parent_jont = prop_motors[k][:parent_jont]
        link = prop_motors[k][:link]
			%>
  <include>
    <uri><%="model://" + link %></uri>
    <name><%="tilt_tricopter_prop_" + k %></name>
    <pose><%= prop_dx %> <%= prop_dy %> <%= prop_dz %> 0 0 0</pose>
  </include>
  <joint name = <%="tilt_tricopter_prop_" + k + '_joint' %> type="revolute">
    <parent><%= parent_jont %></parent>
    <child><%="tilt_tricopter_prop_" + k + '::prop' %></child>
    <axis>
      <xyz>0 0 1</xyz>
      <limit>
        <lower>-1e+16</lower>
        <upper>1e+16</upper>
      </limit>
      <dynamics>
        <damping>0.0001</damping>
      </dynamics>
      <use_parent_model_frame>1</use_parent_model_frame>
    </axis>
  </joint>
  <plugin name = <%= '"prop_' + k + '_plugin"' %> filename='librotors_gazebo_motor_model.so'>
    <robotNamespace></robotNamespace>
    <jointName><%="tilt_tricopter_prop_" + k + '_joint'%> </jointName>
    <linkName><%="tilt_tricopter_prop_" + k + '::prop' %></linkName>
    <turningDirection><%= dir %></turningDirection>
    <timeConstantUp><%= prop_timeConstantUp %></timeConstantUp>
    <timeConstantDown><%= prop_timeConstantDown %></timeConstantDown>
    <maxRotVelocity><%= prop_maxRotVelocity %></maxRotVelocity>
    <motorConstant><%= prop_motorConstant %></motorConstant>
    <momentConstant><%= prop_momentConstant %></momentConstant>
    <commandSubTopic>/gazebo/command/prop_speed</commandSubTopic>
    <motorNumber><%= k %></motorNumber>
    <rotorDragCoefficient>0.000806428</rotorDragCoefficient>
    <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
    <motorSpeedPubTopic><%= 'prop_speed/' + k %></motorSpeedPubTopic>
    <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
  </plugin>
<% end %>
<%# ====================================================================================== %>
<plugin name="ArduRotorTiltTricopter" filename="libArduRotorTiltTricopter.so">
  <fdm_addr>127.0.0.1</fdm_addr>
  <fdm_port_in>9002</fdm_port_in>
  <fdm_port_out>9003</fdm_port_out>
  <modelXYZToAirplaneXForwardZDown>0 0 0 3.141593 0 0</modelXYZToAirplaneXForwardZDown>
  <gazeboXYZToNED>0 0 0 3.141593 0 0</gazeboXYZToNED>
  <motor_num>6</motor_num>
  <servo_num>3</servo_num>
  <motor_pub>/gazebo/command/prop_speed</motor_pub>
  <servo1_pub>/gazebo/command/tilt1_pos</servo1_pub>
  <frontRodLinkName>front_rod</frontRodLinkName>
  <frontRodCollisionName>front_rod_collision</frontRodCollisionName>
  <frontRodContactForceXTopic>/tilt_tricopter/front_rod/contact_force_x</frontRodContactForceXTopic>
  <frontRodContactHoldMs>50.0</frontRodContactHoldMs>
  <cmcuUdpBindAddr>127.0.0.1</cmcuUdpBindAddr>
  <cmcuUdpBindPort>9024</cmcuUdpBindPort>
  <cmcuForceScale>1.0</cmcuForceScale>
  <imuName>tilt_tricopter_base::imu_link::imu_sensor</imuName>
  <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
</plugin>

<plugin name="imu_plugin" filename="librotors_gazebo_imu_plugin.so">
  <robotNamespace>tilt_tricopter</robotNamespace>
  <linkName>tilt_tricopter_base::imu_link</linkName>
  <imuTopic>imu</imuTopic>
  <gyroscopeNoiseDensity>0.000349</gyroscopeNoiseDensity>     <!-- rad/s/√Hz -->
  <gyroscopeBiasRandomWalk>0.000266</gyroscopeBiasRandomWalk>          <!-- rad/s²/√Hz -->
  <gyroscopeBiasCorrelationTime>600</gyroscopeBiasCorrelationTime> <!-- s -->
  <gyroscopeTurnOnBiasSigma>0.0004</gyroscopeTurnOnBiasSigma>  <!-- rad/s -->
  <accelerometerNoiseDensity>0.00324</accelerometerNoiseDensity> <!-- m/s²/√Hz -->
  <accelerometerRandomWalk>0.0056</accelerometerRandomWalk>     <!-- m/s³/√Hz -->
  <accelerometerBiasCorrelationTime>600</accelerometerBiasCorrelationTime> <!-- s -->
  <accelerometerTurnOnBiasSigma>0.016</accelerometerTurnOnBiasSigma> <!-- m/s² -->
</plugin>


</model>
</sdf>
