      <plugin name = tilt_tricopter_tilt_back_0_plugin filename='librotors_gazebo_motor_model.so'>
        <robotNamespace></robotNamespace>
        <jointName>tilt_tricopter_tilt_back_0_joint </jointName>
        <linkName>tilt_tricopter_tilt_back_0::tilt</linkName>
        <turningDirection>cw</turningDirection>
        <motorType>position</motorType>
        <commandSubTopic>/gazebo/command/tilt1_pos</commandSubTopic>
        <motorNumber>1</motorNumber>
        <motorSpeedPubTopic>tilt_pos/1</motorSpeedPubTopic>
        <joint_control_pid>
          <p>3</p>
          <i>1.2</i>
          <d>0.8</d>
          <iMax>10</iMax>
          <iMin>-10</iMin>
          <cmdMax>50</cmdMax>
          <cmdMin>-50</cmdMin>
        </joint_control_pid>
      </plugin>
    
      <include>
        <uri>model://tilt_tricopter_tilt_front</uri>
        <name>tilt_tricopter_tilt_front_1</name>
        <pose>0.70328 0.835 0 0 0 3.141592653589793</pose>
      </include>
      <joint name = tilt_tricopter_tilt_front_1_joint type="revolute">
        <parent>tilt_tricopter_base::base</parent>
        <child>tilt_tricopter_tilt_front_1::tilt</child>
        <axis>
          <xyz>0 -1 0</xyz>
          <limit>
            <lower>-1e+16</lower>
            <upper>1e+16</upper>
          </limit>
          <dynamics>
            <damping>0.1</damping>
            <spring_stiffness>0</spring_stiffness>
            <spring_reference>0</spring_reference>
          </dynamics>
          <use_parent_model_frame>1</use_parent_model_frame>
        </axis>
        <physics>
          <ode>
            <implicit_spring_damper>1</implicit_spring_damper>
          </ode>
        </physics>
      </joint>
