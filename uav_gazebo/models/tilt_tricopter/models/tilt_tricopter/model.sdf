        <robotNamespace></robotNamespace>
        <jointName>tilt_tricopter_tilt_front_1_joint </jointName>
        <linkName>tilt_tricopter_tilt_front_1::tilt</linkName>
        <turningDirection>cw</turningDirection>
        <motorType>position</motorType>
        <commandSubTopic>/gazebo/command/tilt1_pos</commandSubTopic>
        <motorNumber>2</motorNumber>
        <motorSpeedPubTopic>tilt_pos/2</motorSpeedPubTopic>
        <joint_control_pid>
          <p>3</p>
          <i>1.2</i>
          <d>0.8</d>
          <iMax>10</iMax>
          <iMin>-10</iMin>
          <cmdMax>50</cmdMax>
          <cmdMin>-50</cmdMin>
        </joint_control_pid>
      </plugin>
        
  
  
