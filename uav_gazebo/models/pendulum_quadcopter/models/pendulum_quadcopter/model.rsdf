<?xml version="1.0" ?>
<%

# F450 diagonal motor-to-motor span is about 0.45 m.
# In an X frame, each motor sits at diagonal_span / (2 * sqrt(2)).
prop_dx = 0.1591
prop_dy = 0.1591
prop_dz = 0.045

prop_timeConstantUp = 0.0125
prop_timeConstantDown = 0.025
prop_maxRotVelocity = 1000
prop_motorConstant = 8.599e-6
prop_momentConstant = 0.1

prop_motors = {
  "0" => {:dir => "ccw", :x =>  prop_dx, :y => -prop_dy, :yaw => 0},
  "1" => {:dir => "cw",  :x => -prop_dx, :y => -prop_dy, :yaw => 0},
  "2" => {:dir => "ccw", :x => -prop_dx, :y =>  prop_dy, :yaw => Math::PI},
  "3" => {:dir => "cw",  :x =>  prop_dx, :y =>  prop_dy, :yaw => Math::PI},
}

%>
<sdf version="1.5">
  <model name="pendulum_quadcopter">
    <include>
      <uri>model://pendulum_quadcopter_base</uri>
      <name>pendulum_quadcopter_base</name>
      <pose>0 0 0 0 0 0</pose>
    </include>

    <% prop_motors.keys.each do |k|
      motor = prop_motors[k]
    %>
    <include>
      <uri>model://pendulum_quadcopter_prop</uri>
      <name><%= "pendulum_quadcopter_prop_" + k %></name>
      <pose><%= motor[:x] %> <%= motor[:y] %> <%= prop_dz %> 0 0 <%= motor[:yaw] %></pose>
    </include>

    <joint name=<%= '"' + "pendulum_quadcopter_prop_" + k + "_joint" + '"' %> type="revolute">
      <parent>pendulum_quadcopter_base::platform_base</parent>
      <child><%= "pendulum_quadcopter_prop_" + k + "::prop" %></child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>0.00001</damping>
        </dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <plugin name=<%= '"' + "pendulum_quadcopter_prop_" + k + "_plugin" + '"' %> filename="librotors_gazebo_motor_model.so">
      <robotNamespace></robotNamespace>
      <jointName><%= "pendulum_quadcopter_prop_" + k + "_joint" %> </jointName>
      <linkName><%= "pendulum_quadcopter_prop_" + k + "::prop" %></linkName>
      <turningDirection><%= motor[:dir] %></turningDirection>
      <timeConstantUp><%= prop_timeConstantUp %></timeConstantUp>
      <timeConstantDown><%= prop_timeConstantDown %></timeConstantDown>
      <maxRotVelocity><%= prop_maxRotVelocity %></maxRotVelocity>
      <motorConstant><%= prop_motorConstant %></motorConstant>
      <momentConstant><%= prop_momentConstant %></momentConstant>
      <commandSubTopic>/gazebo/command/prop_speed</commandSubTopic>
      <motorNumber><%= k %></motorNumber>
      <rotorDragCoefficient>0.000806428</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic><%= "prop_speed/" + k %></motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
    <% end %>

    <plugin name="ArduRotorNormPlugin" filename="libArduRotorNormPlugin.so">
      <fdm_addr>127.0.0.1</fdm_addr>
      <fdm_port_in>9002</fdm_port_in>
      <fdm_port_out>9003</fdm_port_out>
      <modelXYZToAirplaneXForwardZDown>0 0 0 3.141593 0 0</modelXYZToAirplaneXForwardZDown>
      <gazeboXYZToNED>0 0 0 3.141593 0 0</gazeboXYZToNED>
      <motor_num>4</motor_num>
      <servo_num>0</servo_num>
      <motor_pub>/gazebo/command/prop_speed</motor_pub>
      <imuName>pendulum_quadcopter_base::imu_link::imu_sensor</imuName>
      <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
    </plugin>
  </model>
</sdf>
