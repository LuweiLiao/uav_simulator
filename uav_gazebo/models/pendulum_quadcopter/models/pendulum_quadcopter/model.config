<?xml version="1.0"?>

<model>
  <name>pendulum_quadcopter</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>

  <author>
    <name>uavros_ws</name>
  </author>

  <description>
    Simple box-based X-frame quadcopter model for pendulum experiments.
  </description>

  <depend>
    <model>
      <uri>model://pendulum_quadcopter_base</uri>
      <version>1.0</version>
    </model>
    <model>
      <uri>model://pendulum_quadcopter_prop</uri>
      <version>1.0</version>
    </model>
  </depend>
</model>
