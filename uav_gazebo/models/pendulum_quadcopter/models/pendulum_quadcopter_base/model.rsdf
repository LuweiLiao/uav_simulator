<?xml version="1.0" ?>
<%

# Central body dimensions (meters), roughly matching an F450 center plate.
body_length = 0.18
body_width = 0.18
body_thickness = 0.045

# X-frame arm dimensions (meters). Motor-to-motor diagonal is 0.45 m.
arm_length = 0.45
arm_width = 0.035
arm_thickness = 0.025

# Shallow cup/ring on the top plate for the pendulum foot.  The ring is
# approximated with small wall blocks because SDF primitives do not include a
# hollow cylinder.  It constrains lateral slip without fixing the pole.
cup_inner_radius = 0.1
cup_wall_thickness = 0.006
cup_wall_height = 0.025
cup_center_radius = cup_inner_radius + cup_wall_thickness * 0.5
cup_center_z = body_thickness * 0.5 + cup_wall_height * 0.5
cup_segments = 30
cup_wall_length = 2.0 * Math::PI * cup_center_radius / cup_segments * 1.15

# Whole base link inertial properties. Tune these together with geometry.
platform_base_mass = 1.1
platform_base_ixx = 0.018
platform_base_iyy = 0.018
platform_base_izz = 0.032

%>
<sdf version="1.5">
  <model name="pendulum_quadcopter_platform">
    <link name="platform_base">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass><%= platform_base_mass %></mass>
        <inertia>
          <ixx><%= platform_base_ixx %></ixx>
          <iyy><%= platform_base_iyy %></iyy>
          <izz><%= platform_base_izz %></izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="body_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size><%= body_length %> <%= body_width %> <%= body_thickness %></size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <max_vel>100.0</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>100000.0</mu>
              <mu2>100000.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="body_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size><%= body_length %> <%= body_width %> <%= body_thickness %></size>
          </box>
        </geometry>
        <material>
          <script>
            <name>Gazebo/Grey</name>
          </script>
        </material>
      </visual>

      <collision name="arm_positive_collision">
        <pose>0 0 0 0 0 <%= Math::PI / 4.0 %></pose>
        <geometry>
          <box>
            <size><%= arm_length %> <%= arm_width %> <%= arm_thickness %></size>
          </box>
        </geometry>
      </collision>
      <visual name="arm_positive_visual">
        <pose>0 0 0 0 0 <%= Math::PI / 4.0 %></pose>
        <geometry>
          <box>
            <size><%= arm_length %> <%= arm_width %> <%= arm_thickness %></size>
          </box>
        </geometry>
        <material>
          <script>
            <name>Gazebo/Black</name>
          </script>
        </material>
      </visual>

      <collision name="arm_negative_collision">
        <pose>0 0 0 0 0 <%= -Math::PI / 4.0 %></pose>
        <geometry>
          <box>
            <size><%= arm_length %> <%= arm_width %> <%= arm_thickness %></size>
          </box>
        </geometry>
      </collision>
      <visual name="arm_negative_visual">
        <pose>0 0 0 0 0 <%= -Math::PI / 4.0 %></pose>
        <geometry>
          <box>
            <size><%= arm_length %> <%= arm_width %> <%= arm_thickness %></size>
          </box>
        </geometry>
        <material>
          <script>
            <name>Gazebo/Black</name>
          </script>
        </material>
      </visual>

<% cup_segments.times do |i|
     angle = 2.0 * Math::PI * i / cup_segments
     x = cup_center_radius * Math.cos(angle)
     y = cup_center_radius * Math.sin(angle)
%>
      <collision name=<%= '"' + "pendulum_cup_collision_" + i.to_s + '"' %>>
        <pose><%= x %> <%= y %> <%= cup_center_z %> 0 0 <%= angle %></pose>
        <geometry>
          <box>
            <size><%= cup_wall_length %> <%= cup_wall_thickness %> <%= cup_wall_height %></size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <max_vel>100.0</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>100000.0</mu>
              <mu2>100000.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name=<%= '"' + "pendulum_cup_visual_" + i.to_s + '"' %>>
        <pose><%= x %> <%= y %> <%= cup_center_z %> 0 0 <%= angle %></pose>
        <geometry>
          <box>
            <size><%= cup_wall_length %> <%= cup_wall_thickness %> <%= cup_wall_height %></size>
          </box>
        </geometry>
        <material>
          <script>
            <name>Gazebo/Blue</name>
          </script>
        </material>
      </visual>
<% end %>
    </link>

    <link name="imu_link">
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00002</iyy>
          <iyz>0</iyz>
          <izz>0.00002</izz>
        </inertia>
      </inertial>
      <sensor name="imu_sensor" type="imu">
        <pose>0 0 0 3.141593 0 0</pose>
        <always_on>1</always_on>
        <update_rate>1000.0</update_rate>
        <topic>__default_topic__</topic>
      </sensor>
    </link>

    <joint name="imu_joint" type="fixed">
      <parent>platform_base</parent>
      <child>imu_link</child>
    </joint>
  </model>
</sdf>
