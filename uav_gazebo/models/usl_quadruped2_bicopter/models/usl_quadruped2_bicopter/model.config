<?xml version="1.0"?>

<model>
  <name>usl_quadruped2_bicopter</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>

  <author>
    <name>Luwei Liao</name>
    <email>liaoluweillw@163.com</email>
  </author>

  <maintainer email="liaoluweillw@163.com">Luwei Liao</maintainer>


  <description>
    starting with iris_with_standoffs
    add LiftDragPlugin
    add ArduCopterPlugin
    attach gimbal_small_2d model with GimbalSmall2dPlugin
  </description>
  <depend>
    <model>
      <uri>model://usl_quadruped2_bicopter_base</uri>
      <version>1.0</version>
    </model>
    <model>
      <uri>model://usl_quadruped2_bicopter_coxa</uri>
      <version>1.0</version>
    </model>

    <model>
      <uri>model://usl_quadruped2_bicopter_femur</uri>
      <version>1.0</version>
    </model>
    
    <model>
      <uri>model://usl_quadruped2_bicopter_tibia</uri>
      <version>1.0</version>
    </model>
    
    <model>
      <uri>model://usl_quadruped2_bicopter_tilt</uri>
      <version>1.0</version>
    </model>
    
    <model>
      <uri>model://usl_quadruped2_bicopter_prop</uri>
      <version>1.0</version>
    </model>


  </depend>
</model>