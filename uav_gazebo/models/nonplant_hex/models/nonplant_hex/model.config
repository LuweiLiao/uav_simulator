<?xml version="1.0"?>

<model>
  <name>nonplant_hex</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>

  <author>
    <name>uavros</name>
    <email>uavros@example.com</email>
  </author>

  <maintainer email="uavros@example.com">uavros</maintainer>

  <description>
    Non-coplanar hexrotor: 6 arms with fixed-tilt propellers (alternating roll
    along the arm axis) for fully-actuated control. Uses ArduRotorNormPlugin.
  </description>

  <depend>
    <model>
      <uri>model://nonplant_hex_base</uri>
      <version>1.0</version>
    </model>
    <model>
      <uri>model://nonplant_hex_arm</uri>
      <version>1.0</version>
    </model>
    <model>
      <uri>model://nonplant_hex_prop</uri>
      <version>1.0</version>
    </model>
  </depend>
</model>
